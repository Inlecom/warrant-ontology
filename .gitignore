# WARRaNT KG Ontology Repository — .gitignore

# ── Build artefacts ──────────────────────────────────────────────────────────
# Never commit merged or WIDOCO-prep outputs
dist/

# WIDOCO-generated HTML docs (regenerated by CI / scripts/generate_docs)
docs/html/

docs/arrows

# ── WIDOCO tooling ───────────────────────────────────────────────────────────
scripts/widoco.jar
scripts/widoco-*.jar

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
env/
.python-version

# ── Java ─────────────────────────────────────────────────────────────────────
*.class
*.jar

# ── OS and editor ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Protégé ──────────────────────────────────────────────────────────────────
# Protégé creates these alongside ontology files
*.log
catalog-v001.xml

# ── AI agent local config ────────────────────────────────────────────────────
# Claude Code (Anthropic)
.claude/
# Cursor
.cursor/
# GitHub Copilot
.copilot/
# Aider
.aider*
# Continue.dev
.continue/
# Codeium / Windsurf
.codeium/
.windsurfRules

# ── Secrets / local config ───────────────────────────────────────────────────
.env*
*.env.local
secrets/
