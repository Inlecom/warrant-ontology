##############################################################################
# WARRaNT Example: LL1 Containership Navigation/Comms OT Dependability
# Instance namespace: https://warrant-project.eu/data/ll1#
# Ontology version: 1.0.0
# Source documents:
#   - Block diagram of bridge navigation equipment (H/N 4009/4010/4011/4012)
#   - Bridge navigation equipment interconnection interface details
#   - Cyber security Equipment sw list V145-148 (vessel CATHERINE C, V145)
#   - FMEA OT V145-148 (Navigation/Communication OT + Electrical/Automation OT)
#   - WARRaNT LL1 scenario: AIS/ECDIS spoofing cyber-attack
#
# Scope: Danaos containership fleet (hull 4009–4012). Navigation & Comms OT.
#
# Vessel functions modelled:
#   VF-NAV-001  Navigation (position fixing, chart display, course keeping)
#   VF-COM-001  Communication (VHF/MF-HF/Inmarsat, distress alerting)
#   VF-VDR-001  Voyage Data Recording (black-box, accident investigation)
#   VF-EL-001   Electrical OT & Alarm Monitoring (AMS, fire detection, BNWAS)
#
# Key FMEA failure modes included (by RPN priority):
#   AMS change data              RPN=315 (Sev=7, Prob=9, Det=5)
#   VDR data modified/erased     RPN=180 (Sev=6, Prob=6, Det=5)
#   VDR data not stored          RPN=175 (Sev=7, Prob=5, Det=5)
#   RADAR/ECDIS/GPS settings mod RPN=108 (Sev=6, Prob=6, Det=3)
#   BNWAS settings modified      RPN=108 (Sev=6, Prob=6, Det=3)
#   SPEEDLOG settings modified   RPN=105 (Sev=7, Prob=5, Det=3)
#   ECHOSOUNDER settings mod     RPN=105 (Sev=7, Prob=5, Det=3)
#   NAVTEX settings modified     RPN=105 (Sev=7, Prob=5, Det=3)
#   GPS signal jammed            RPN= 63 (Sev=7, Prob=3, Det=3)
#   GYROCOMPASS settings mod     RPN= 63 (Sev=7, Prob=3, Det=3)
#
# Primary cyber scenario:
#   Adversary injects spoofed AIS data → ECDIS displays false vessel position
#   → Navigation officer issues wrong course alteration → collision/grounding risk
#
# ── ONTOLOGY STATUS ──────────────────────────────────────────────────────────
#
# FLAG-01 RESOLVED: cdm:FailureMode, cdm:affectsComponent, cdm:producesDeviation
#   now defined in warrant-cdm.ttl.
#
# FLAG-02 RESOLVED: warrant:hasMaker, warrant:hasModel, warrant:hasSoftwareVersion
#   now defined in warrant-core.ttl. All components use typed triples.
#
# FLAG-03 RESOLVED: davom:hasInterfaceType + davom:InterfaceType controlled
#   vocabulary (LAN, SERIAL, CONTACT, SERIAL_CONTACT, VIDEO, AUDIO, WIRELESS)
#   now defined in warrant-davom.ttl. All CommunicationLinks typed.
#
# FLAG-04 DEFERRED: cdm:hasSeverityScore, cdm:hasProbabilityScore,
#   cdm:hasDetectionScore, cdm:hasRPN (integer FMEA 1–10 scales).
#   FMEA scores remain in warrant:hasDescription until FMEA-to-KG pipeline
#   is formalised in T1.1/T1.4 discussions.
#
##############################################################################

@prefix ll1:     <https://warrant-project.eu/data/ll1#> .
@prefix warrant: <https://warrant-project.eu/ontology/core#> .
@prefix davom:   <https://warrant-project.eu/ontology/davom#> .
@prefix obs:     <https://warrant-project.eu/ontology/observation#> .
@prefix cdm:     <https://warrant-project.eu/ontology/cdm#> .
@prefix assr:    <https://warrant-project.eu/ontology/assurance#> .
@prefix di:      <https://warrant-project.eu/ontology/dependability-index#> .
@prefix mit:     <https://warrant-project.eu/ontology/mitigation#> .
@prefix dt:      <https://warrant-project.eu/ontology/digital-twin#> .
@prefix scen:    <https://warrant-project.eu/ontology/scenario#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .


# ═══════════════════════════════════════════════════════════════════════════════
# VESSEL
# ═══════════════════════════════════════════════════════════════════════════════

ll1:ContainerVessel_LL1 a davom:Vessel ;
    warrant:hasIdentifier "LL1-VESSEL-V145" ;
    warrant:hasName "LL1 Containership (Danaos — CATHERINE C, V145)" ;
    warrant:hasDescription "Danaos containership hull 4009/4010/4011/4012. Reference vessel for WARRaNT LL1. Navigation and communications OT scope." .


# ═══════════════════════════════════════════════════════════════════════════════
# VESSEL FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════════════

ll1:NavigationFunction a davom:VesselFunction ;
    warrant:hasIdentifier "VF-NAV-001" ;
    warrant:hasName "Navigation Function" ;
    warrant:hasDescription "Position fixing, chart display (ECDIS), course keeping (Autopilot), target tracking (RADAR), and speed/depth sensing." .

ll1:CommunicationFunction a davom:VesselFunction ;
    warrant:hasIdentifier "VF-COM-001" ;
    warrant:hasName "Communication Function" ;
    warrant:hasDescription "Short-range (VHF), long-range (MF/HF), satellite (Inmarsat-C/GX/FBB), and AIS vessel identification and distress alerting." .

ll1:VoyageRecordingFunction a davom:VesselFunction ;
    warrant:hasIdentifier "VF-VDR-001" ;
    warrant:hasName "Voyage Data Recording Function" ;
    warrant:hasDescription "Black-box voyage data recording (VDR/SVDR) for accident investigation; receives audio, video, serial, and contact inputs from bridge equipment." .

ll1:ElectricalAlarmFunction a davom:VesselFunction ;
    warrant:hasIdentifier "VF-EL-001" ;
    warrant:hasName "Electrical OT and Alarm Monitoring Function" ;
    warrant:hasDescription "Alarm monitoring system (AMS), bridge navigational watch alarm (BNWAS), fire detection, general alarm, and navigation lights." .

ll1:ContainerVessel_LL1 davom:hasFunction ll1:NavigationFunction .
ll1:ContainerVessel_LL1 davom:hasFunction ll1:CommunicationFunction .
ll1:ContainerVessel_LL1 davom:hasFunction ll1:VoyageRecordingFunction .
ll1:ContainerVessel_LL1 davom:hasFunction ll1:ElectricalAlarmFunction .


# ═══════════════════════════════════════════════════════════════════════════════
# SYSTEMS
# ═══════════════════════════════════════════════════════════════════════════════

ll1:NavigationSystem a davom:TechnicalSystem ;
    warrant:hasIdentifier "SYS-NAV-001" ;
    warrant:hasName "Bridge Navigation System" ;
    warrant:hasDescription "Integrated bridge navigation system covering RADAR, ECDIS, GPS, Gyrocompass, Autopilot, Speedlog, Echosounder, Anemometer, AIS, and BNWAS." .

ll1:CommunicationSystem a davom:CommunicationSystem ;
    warrant:hasIdentifier "SYS-COM-001" ;
    warrant:hasName "Bridge Communication System" ;
    warrant:hasDescription "Ship communication system: VHF (×3), MF/HF, Inmarsat-C (×2), Inmarsat GX, Inmarsat FBB-500, Navtex, and Communications PC." .

ll1:VDRSystem a davom:TechnicalSystem ;
    warrant:hasIdentifier "SYS-VDR-001" ;
    warrant:hasName "Voyage Data Recorder System (SVDR)" ;
    warrant:hasDescription "Simplified Voyage Data Recorder: FURUNO VR-7017, sw 24550103-01.63. Central data hub receiving serial, contact, video, and audio from all bridge OT." .

ll1:AlarmMonitoringSystem a davom:CyberPhysicalSystem ;
    warrant:hasIdentifier "SYS-AMS-001" ;
    warrant:hasName "Alarm Monitoring System (AMS)" ;
    warrant:hasDescription "Integrated alarm monitoring system for engine room and vessel-wide alerting. Interconnected with VDR and BNWAS via SERIAL/CONTACT. FMEA RPN=315 (highest in electrical OT)." .

ll1:NavigationFunction      davom:isSupportedBy ll1:NavigationSystem .
ll1:CommunicationFunction   davom:isSupportedBy ll1:CommunicationSystem .
ll1:VoyageRecordingFunction davom:isSupportedBy ll1:VDRSystem .
ll1:VoyageRecordingFunction davom:isSupportedBy ll1:NavigationSystem .
ll1:ElectricalAlarmFunction davom:isSupportedBy ll1:AlarmMonitoringSystem .


